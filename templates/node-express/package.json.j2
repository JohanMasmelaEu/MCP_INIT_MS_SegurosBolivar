{
{% if npm_scope %}
  "name": "{{ npm_scope }}/{{ project_name }}",
{% else %}
  "name": "{{ project_name }}",
{% endif %}
  "version": "{{ api_version }}",
  "description": "{{ api_description }}",
  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "express": "4.21.2",
    "zod": "3.23.8",
    "pg": "8.13.1",
    "drizzle-orm": "0.36.4",
    "pino": "9.5.0",
    "helmet": "8.0.0",
    "cors": "2.8.5",
    "hpp": "0.2.3",
    "express-rate-limit": "7.4.1",
    "@aws-sdk/client-ssm": "3.700.0",
{% if auth_strategy == "oauth2-resource-server" %}
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "jsonwebtoken": "9.0.2",
{% elif auth_strategy == "machine-to-machine" %}
    "jsonwebtoken": "9.0.2",
{% endif %}
{% if cache == "redis" %}
    "ioredis": "5.4.2",
{% endif %}
{% if integrations.uses_s3 %}
    "@aws-sdk/client-s3": "3.700.0",
    "@aws-sdk/s3-request-presigner": "3.700.0",
{% endif %}
{% if integrations.uses_sqs %}
    "@aws-sdk/client-sqs": "3.700.0",
{% endif %}
    "swagger-ui-express": "5.0.1"
  },
  "devDependencies": {
    "typescript": "5.5.4",
    "tsx": "4.19.2",
    "@types/express": "5.0.0",
    "@types/cors": "2.8.17",
    "@types/hpp": "0.2.6",
    "@types/pg": "8.11.10",
{% if auth_strategy == "oauth2-resource-server" %}
    "@types/passport": "1.0.17",
    "@types/passport-jwt": "4.0.1",
    "@types/jsonwebtoken": "9.0.7",
{% elif auth_strategy == "machine-to-machine" %}
    "@types/jsonwebtoken": "9.0.7",
{% endif %}
    "@types/swagger-ui-express": "4.1.7",
    "drizzle-kit": "0.28.1",
    "vitest": "2.1.8",
    "@vitest/coverage-v8": "2.1.8",
    "supertest": "7.0.0",
    "@types/supertest": "6.0.2",
    "@faker-js/faker": "9.2.0",
    "nock": "14.0.1",
    "eslint": "9.14.0",
    "@typescript-eslint/eslint-plugin": "8.13.0",
    "@typescript-eslint/parser": "8.13.0",
    "prettier": "3.4.2",
    "pino-pretty": "13.0.0"
{% if use_husky %}
    ,
    "husky": "9.1.7",
    "lint-staged": "15.2.10"
{% endif %}
  },
{% if use_husky %}
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
{% endif %}
  "trustedDependencies": []
}
