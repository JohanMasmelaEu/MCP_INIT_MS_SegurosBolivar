# ============================================================
# Variables de Entorno — {{ project_name }}
# Copiar a .env y configurar valores reales
# ============================================================

NODE_ENV=local
APP_PORT={{ app_port }}

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT={{ db.db_port }}
DB_NAME={{ db.db_name }}
DB_USER={{ db.db_user }}
DB_PASSWORD={{ db.db_password }}
DB_SCHEMA={{ db.db_schema }}
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

{% if auth_strategy == "oauth2-resource-server" %}
# --- OAuth2 ---
OAUTH_JWKS_URI=http://localhost:8888/default/.well-known/jwks.json
OAUTH_ISSUER=http://localhost:8888/default
OAUTH_AUDIENCE={{ project_name }}
OAUTH_SECRET=mock-secret-for-local-dev
{% endif %}

{% if cache == "redis" %}
# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT={{ redis_port }}
REDIS_PASSWORD=
{% endif %}

# --- AWS / LocalStack ---
AWS_REGION=us-east-1
AWS_ENDPOINT=http://localhost:{{ localstack_port }}
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SSM_PREFIX={{ ssm_app_prefix }}

# --- Observability ---
DD_SERVICE={{ dd_service }}
DD_ENV=local
LOG_LEVEL=debug

# --- Artifactory (para npm ci en pipeline) ---
# ARTIFACTORY_USER=
# ARTIFACTORY_PASSWORD=
