import { AsyncLocalStorage } from "node:async_hooks";
import { randomUUID } from "node:crypto";
import type { Request, Response, NextFunction } from "express";

const HEADER_NAME = "x-correlation-id";

/**
 * AsyncLocalStorage para propagar el correlation-id a logs y downstream calls.
 */
const correlationStorage = new AsyncLocalStorage<string>();

/**
 * Middleware que lee X-Correlation-ID del request o genera uno nuevo.
 * Lo almacena en AsyncLocalStorage para acceso global.
 */
export function correlationIdMiddleware(req: Request, res: Response, next: NextFunction): void {
  const correlationId = (req.headers[HEADER_NAME] as string) ?? randomUUID();

  // Setear header en response
  res.setHeader(HEADER_NAME, correlationId);

  // Correr el resto del request dentro del contexto
  correlationStorage.run(correlationId, () => {
    next();
  });
}

/**
 * Obtiene el correlation-id del contexto actual.
 * Retorna undefined si se llama fuera de un request.
 */
export function getCorrelationId(): string | undefined {
  return correlationStorage.getStore();
}
