import type { Request, Response, NextFunction } from "express";
import { logger } from "../config/logger.js";

/**
 * Middleware que registra cada request entrante y su duracion.
 * Masking de headers sensibles en produccion.
 */
export function requestLoggerMiddleware(req: Request, res: Response, next: NextFunction): void {
  const start = Date.now();

  res.on("finish", () => {
    const duration = Date.now() - start;
    const logData = {
      method: req.method,
      path: req.path,
      statusCode: res.statusCode,
      duration,
      userAgent: req.headers["user-agent"],
    };

    if (res.statusCode >= 500) {
      logger.error(logData, "Request completado con error");
    } else if (res.statusCode >= 400) {
      logger.warn(logData, "Request completado con error de cliente");
    } else {
      logger.info(logData, "Request completado");
    }
  });

  next();
}
