  /**
   * Actualiza un {{ m.entity_name }} existente.
   */
  async actualizar(id: number, dto: Actualizar{{ m.entity_name }}Dto): Promise<{{ m.entity_name }}Response> {
    const existing = await this.repository.buscarPorId(id);
    if (!existing) {
      throw new BolivarBusinessError({
        codigo: "{{ m.entity_name | upper }}_NO_ENCONTRADO",
        mensaje: `{{ m.entity_name }} con id ${id} no encontrado`,
        categoria: ErrorType.NEGOCIO,
        httpStatus: 404,
      });
    }
    const updated = await this.repository.actualizar(id, dto);
    return this.toResponse(updated);
  }

  /**
   * Elimina un {{ m.entity_name }} por su ID.
   */
  async eliminar(id: number): Promise<void> {
    const existing = await this.repository.buscarPorId(id);
    if (!existing) {
      throw new BolivarBusinessError({
        codigo: "{{ m.entity_name | upper }}_NO_ENCONTRADO",
        mensaje: `{{ m.entity_name }} con id ${id} no encontrado`,
        categoria: ErrorType.NEGOCIO,
        httpStatus: 404,
      });
    }
    await this.repository.eliminar(id);
  }

  /**
   * Mapea entity a DTO de respuesta.
   */
  private toResponse(entity: Record<string, unknown>): {{ m.entity_name }}Response {
    return entity as unknown as {{ m.entity_name }}Response;
  }
}
