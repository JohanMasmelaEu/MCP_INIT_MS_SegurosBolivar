  async listar(
    filtros: Record<string, unknown>,
    paginacion: PaginationParams,
  ): Promise<{ data: {{ m.entity_name }}Response[]; total: number }> {
    const { data, total } = await this.repository.listarConFiltros(filtros, paginacion);
    return {
