import { {{ m.entity_name }}Repository } from "./{{ m.module_name }}.repository.js";
import type { Crear{{ m.entity_name }}Dto } from "./dto/crear.dto.js";
import type { Actualizar{{ m.entity_name }}Dto } from "./dto/actualizar.dto.js";
import type { {{ m.entity_name }}Response } from "./dto/response.dto.js";
import type { PaginationParams } from "../commons/pagination.dto.js";
import { BolivarBusinessError } from "../errors/bolivar-business.error.js";
import { ErrorType } from "../errors/error-types.enum.js";

/**
 * Servicio de negocio para {{ m.entity_name }}.
 * Contiene la logica de dominio y orquesta el repository.
 */
export class {{ m.entity_name }}Service {
  private readonly repository: {{ m.entity_name }}Repository;

  constructor() {
    this.repository = new {{ m.entity_name }}Repository();
  }

  /**
   * Crea un nuevo {{ m.entity_name }}.
   */
  async crear(dto: Crear{{ m.entity_name }}Dto): Promise<{{ m.entity_name }}Response> {
    const entity = await this.repository.insertar(dto);
    return this.toResponse(entity);
