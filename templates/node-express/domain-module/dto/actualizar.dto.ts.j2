import { z } from "zod";

/**
 * Schema Zod para actualizacion parcial de {{ m.entity_name }}.
 * Todos los campos son opcionales (PATCH semantics).
 */
export const actualizar{{ m.entity_name }}Schema = z.object({
{% for field in m.fields %}
{% if field.field_type.value == "String" %}
  {{ field.name }}: z.string(){% if field.length %}.max({{ field.length }}){% endif %}.trim().optional(),
{% elif field.field_type.value == "Long" or field.field_type.value == "Integer" %}
  {{ field.name }}: z.number().int().optional(),
{% elif field.field_type.value == "Boolean" %}
  {{ field.name }}: z.boolean().optional(),
{% elif field.field_type.value == "BigDecimal" %}
  {{ field.name }}: z.number().positive().optional(),
{% elif field.field_type.value == "LocalDate" %}
  {{ field.name }}: z.string().date().optional(),
{% elif field.field_type.value == "LocalDateTime" %}
  {{ field.name }}: z.string().datetime().optional(),
{% elif field.field_type.value == "UUID" %}
  {{ field.name }}: z.string().uuid().optional(),
{% endif %}
{% endfor %}
});

export type Actualizar{{ m.entity_name }}Dto = z.infer<typeof actualizar{{ m.entity_name }}Schema>;
