        entities, total = await self._repository.listar_con_filtros(filtros, pagination)
        return [{{ m.entity_name }}ResponseSchema.model_validate(e) for e in entities], total

    async def obtener_por_id(self, item_id: int) -> {{ m.entity_name }}ResponseSchema:
        """Obtiene un {{ m.entity_name }} por ID.

