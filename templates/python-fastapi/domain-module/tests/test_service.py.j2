class TestObtenerPorId:
    """Tests para {{ m.entity_name }}Service.obtener_por_id."""

    async def test_retorna_entidad_cuando_existe(
        self, service: {{ m.entity_name }}Service, mock_repository: AsyncMock
    ) -> None:
        """Debe retornar la entidad si existe."""
        # Arrange
        mock_entity = MagicMock()
        mock_entity.id = 1
        mock_repository.buscar_por_id.return_value = mock_entity

        # Act
        resultado = await service.obtener_por_id(1)

        # Assert
        assert resultado.id == 1

    async def test_lanza_error_cuando_no_existe(
        self, service: {{ m.entity_name }}Service, mock_repository: AsyncMock
    ) -> None:
        """Debe lanzar BolivarBusinessError si no existe."""
        # Arrange
        mock_repository.buscar_por_id.return_value = None

        # Act & Assert
        with pytest.raises(BolivarBusinessError) as exc_info:
            await service.obtener_por_id(999)
        assert exc_info.value.http_status == 404


