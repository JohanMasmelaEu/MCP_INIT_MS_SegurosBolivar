"""Configuracion validada de la aplicacion via Pydantic Settings.

Carga variables desde .env y valida tipos al iniciar.
"""

from functools import lru_cache

from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    """Variables de entorno validadas."""

    model_config = SettingsConfigDict(env_file=".env", env_file_encoding="utf-8", extra="ignore")

    # App
    app_env: str = "local"
    app_port: int = {{ app_port }}

    # Database
    db_host: str = "localhost"
    db_port: int = {{ db.db_port }}
    db_name: str = "{{ db.db_name }}"
    db_user: str = "{{ db.db_user }}"
    db_password: str = "{{ db.db_password }}"
    db_schema: str = "{{ db.db_schema }}"
    db_pool_min: int = 2
    db_pool_max: int = 10

    # CORS
    cors_allowed_origins: list[str] = ["http://localhost:3000", "http://localhost:5173"]

{% if auth_strategy == "oauth2-resource-server" %}
    # OAuth2
    oauth_jwks_uri: str = "http://localhost:8888/default/.well-known/jwks.json"
    oauth_issuer: str = "http://localhost:8888/default"
    oauth_audience: str | None = "{{ project_name }}"
    oauth_secret: str = "mock-secret-for-local-dev"
{% endif %}

{% if cache == "redis" %}
    # Redis
    redis_host: str = "localhost"
    redis_port: int = {{ redis_port }}
    redis_password: str | None = None
{% endif %}

    # AWS / LocalStack
    aws_region: str = "us-east-1"
    aws_endpoint: str | None = "http://localhost:{{ localstack_port }}"
    ssm_prefix: str = "{{ ssm_app_prefix }}"

    # Observability
    dd_service: str = "{{ dd_service }}"
    dd_env: str = "local"
    log_level: str = "INFO"

    @property
    def database_url(self) -> str:
        """URL de conexion PostgreSQL async."""
        return (
            f"postgresql+asyncpg://{self.db_user}:{self.db_password}"
            f"@{self.db_host}:{self.db_port}/{self.db_name}"
        )


@lru_cache
def get_settings() -> Settings:
    """Retorna instancia cacheada de Settings."""
    return Settings()
