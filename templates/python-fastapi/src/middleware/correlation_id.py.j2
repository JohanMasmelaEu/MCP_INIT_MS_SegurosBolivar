"""Middleware de Correlation ID con contextvars."""

from contextvars import ContextVar
from uuid import uuid4

from starlette.middleware.base import BaseHTTPMiddleware, RequestResponseEndpoint
from starlette.requests import Request
from starlette.responses import Response

HEADER_NAME = "x-correlation-id"

_correlation_id_ctx: ContextVar[str | None] = ContextVar("correlation_id", default=None)


class CorrelationIdMiddleware(BaseHTTPMiddleware):
    """Lee X-Correlation-ID del request o genera uno nuevo.

    Lo almacena en ContextVar para propagacion a logs y downstream calls.
    """

    async def dispatch(self, request: Request, call_next: RequestResponseEndpoint) -> Response:
        """Procesa el request inyectando correlation id."""
        correlation_id = request.headers.get(HEADER_NAME) or str(uuid4())
        _correlation_id_ctx.set(correlation_id)

        response = await call_next(request)
        response.headers[HEADER_NAME] = correlation_id
        return response


def get_correlation_id() -> str | None:
    """Obtiene el correlation-id del contexto actual.

    Returns:
        Correlation ID o None si se llama fuera de un request.
    """
    return _correlation_id_ctx.get()
