"""Mixin de auditoria para modelos SQLAlchemy."""

from datetime import datetime, timezone

from sqlalchemy import String
from sqlalchemy.orm import Mapped, mapped_column


class AuditMixin:
    """Mixin que agrega campos de auditoria a modelos SQLAlchemy.

    Campos:
        creado_por: Usuario que creo el registro.
        fecha_creacion: Timestamp de creacion (UTC).
        modificado_por: Usuario de la ultima modificacion.
        fecha_modificacion: Timestamp de la ultima modificacion.
    """

    creado_por: Mapped[str] = mapped_column(
        String(100), nullable=False, default="system"
    )
    fecha_creacion: Mapped[datetime] = mapped_column(
        nullable=False, default=lambda: datetime.now(timezone.utc)
    )
    modificado_por: Mapped[str | None] = mapped_column(String(100), nullable=True)
    fecha_modificacion: Mapped[datetime | None] = mapped_column(nullable=True)
