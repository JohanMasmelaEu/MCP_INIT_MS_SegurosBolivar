server:
  port: ${SERVER_PORT:{{ app_port }}}
  servlet:
    context-path: {{ context_path }}

management:
  endpoint:
    health:
      show-details: always
  endpoints:
    web:
      exposure:
        include: mappings, health
      base-path: /actuator

info:
  status: UP

spring:
  application:
    name: {{ context_path_clean }}
  data:
    web:
      pageSerializationMode: VIA_DTO
{% if cache == "redis" %}
    redis:
      host: ${APP_REDIS_HOST:localhost}
      port: ${APP_REDIS_PORT:{{ redis_port }}}
      timeout: 5000ms
{% endif %}
  servlet:
    multipart:
      max-file-size: 8MB
      max-request-size: 8MB
    encoding:
      charset: UTF-8
      force-response: true
  jpa:
    open-in-view: false

logging:
  level:
    {{ base_package }}: TRACE

app:
  cors:
    allowed-origins: ${APP_CORS_ALLOWED_ORIGINS:}
    allowed-origin-patterns: "${APP_CORS_ALLOWED_ORIGIN_PATTERNS:http://localhost:*,http://127.0.0.1:*,https://localhost:*,https://127.0.0.1:*}"
    allow-credentials: ${APP_CORS_ALLOW_CREDENTIALS:{{ cors_allow_credentials | lower }}}
  database:
    host-override: ${APP_DATABASE_HOST_OVERRIDE:}
    rds-ssl-root-cert: ${APP_DATABASE_RDS_SSL_ROOT_CERT:}
{% if integrations.uses_s3 %}
  s3:
    bucket: ${APP_S3_BUCKET:{{ context_path_clean }}-dev-files}
    key-prefix: archivos/
    region: ${APP_S3_REGION:}
    presign-upload-expiration-minutes: 15
    presign-download-expiration-minutes: 5
    max-file-size-bytes: 10485760
{% endif %}
  auth:
    use-api-gateway: ${APP_AUTH_USE_API_GATEWAY:{% if auth_strategy == "api-gateway-delegated" %}true{% else %}false{% endif %}}
{% if auth_strategy == "oauth2-resource-server" %}
  oauth:
    cognito:
      domain: ${APP_OAUTH_COGNITO_DOMAIN:control-acceso-ui-pool-{{ context_path_clean }}-dev.auth.us-east-1.amazoncognito.com}
      client-id: ${APP_OAUTH_COGNITO_CLIENT_ID:}
      client-secret: ${APP_OAUTH_COGNITO_CLIENT_SECRET:}
      client-secret-name: ${APP_OAUTH_COGNITO_CLIENT_SECRET_NAME:{{ db.ssm_prefix or ssm_app_prefix + '/dev' }}/cognito/client-secret}
      redirect-uri-allowlist:
        - https://{{ context_path_clean }}-dev.bolnet.com.co/login
        - http://localhost:4200/login
      token-uri-scheme: ${APP_OAUTH_COGNITO_TOKEN_URI_SCHEME:https}
      token-uri-path: ${APP_OAUTH_COGNITO_TOKEN_URI_PATH:/oauth2/token}
      token-uri-scheme-host-delimiter: ${APP_OAUTH_COGNITO_TOKEN_URI_SCHEME_HOST_DELIMITER:"://"}
      domain-http-scheme: ${APP_OAUTH_COGNITO_DOMAIN_HTTP_SCHEME:http}
      connect-timeout-ms: ${APP_OAUTH_COGNITO_CONNECT_TIMEOUT_MS:10000}
      read-timeout-ms: ${APP_OAUTH_COGNITO_READ_TIMEOUT_MS:30000}
    refresh-cookie:
      name: {{ context_path_clean }}_refresh_token
      path: ${APP_OAUTH_REFRESH_COOKIE_PATH:/dev{{ context_path }}}
      max-age-seconds: ${APP_OAUTH_REFRESH_COOKIE_MAX_AGE_SECONDS:28800}
      secure: true
      same-site: None
{% elif auth_strategy == "machine-to-machine" %}
  jwt:
    signing-key: ${APP_JWT_SIGNING_KEY:}
    ttl-seconds: ${APP_JWT_TTL_SECONDS:3600}
{% endif %}
  aws:
    env_prefix: /${ENV_PREFIX:dev}
    db-params:
      endpoint: {{ db.ssm_endpoint_resolved }}
      database-name: {{ db.ssm_dbname_resolved }}
      username: {{ db.ssm_username_resolved }}
      password: {{ db.ssm_password_resolved }}
{% if auth_strategy == "machine-to-machine" %}
    jwt-params:
      signing-key: {{ db.ssm_prefix or ssm_app_prefix + '/dev' }}/jwt/signing-key
      ttl-seconds: {{ db.ssm_prefix or ssm_app_prefix + '/dev' }}/jwt/ttl-seconds
{% endif %}
{% if cache == "redis" %}
    redis-params:
      host: {{ db.ssm_prefix or ssm_app_prefix + '/dev' }}/redis/host
      port: {{ db.ssm_prefix or ssm_app_prefix + '/dev' }}/redis/port
{% endif %}
  parameter-store:
    enabled: ${APP_PARAMETER_STORE_ENABLED:true}
  openapi:
    server-local-url: ${APP_OPENAPI_SERVER_LOCAL_URL:http://localhost:{{ app_port }}{{ context_path }}}
    server-dev-url: ${APP_OPENAPI_SERVER_DEV_URL:}
    server-qa-url: ${APP_OPENAPI_SERVER_QA_URL:}
    server-prod-url: ${APP_OPENAPI_SERVER_PROD_URL:}

springdoc:
  api-docs:
    path: {{ openapi_path }}
    enabled: true
  swagger-ui:
    path: /swagger-ui.html
    enabled: true
    doc-expansion: list

bolivar:
  api:
    doc:
      api-title: API {{ api_description }}
      api-description: {{ api_description }}
      api-terms-of-service: ""
      api-contact:
        name: Equipo {{ project_name }}
        email: ""
      api-license:
        name: Apache 2.0
        url: http://www.apache.org/licenses/LICENSE-2.0.html
      api-version: {{ api_version }}
  centralizador:
    exclusions: 'mappings, health, srv, swagger, openapi'
