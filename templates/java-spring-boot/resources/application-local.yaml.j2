---
spring:
  config:
    activate:
      on-profile: local

server:
  port: ${SERVER_PORT:{{ app_port }}}
{% if cache == "redis" %}

  # Redis local (fuera de Docker: apunta a host directo)
spring:
  data:
    redis:
      host: ${APP_REDIS_HOST:localhost}
      port: ${APP_REDIS_PORT:{{ redis_port }}}
{% endif %}

app:
  cors:
    allowed-origin-patterns: "http://localhost:*,http://127.0.0.1:*,http://[::1]:*,https://localhost:*,https://127.0.0.1:*,https://host.docker.internal:*"
{% if auth_strategy == "oauth2-resource-server" %}
  oauth:
    cognito:
      domain: ${APP_OAUTH_COGNITO_DOMAIN:localhost:8090}
      client-id: ${APP_OAUTH_COGNITO_CLIENT_ID:{{ context_path_clean }}-local-client}
      client-secret: ${APP_OAUTH_COGNITO_CLIENT_SECRET:{{ context_path_clean }}-local-secret}
      client-secret-name: ${APP_OAUTH_COGNITO_CLIENT_SECRET_NAME:}
      token-uri-scheme: ${APP_OAUTH_COGNITO_TOKEN_URI_SCHEME:http}
      token-uri-path: ${APP_OAUTH_COGNITO_TOKEN_URI_PATH:/default/token}
    refresh-cookie:
      path: {{ context_path }}
{% elif auth_strategy == "machine-to-machine" %}
  auth:
    jwt:
      signing-key: ${APP_JWT_SIGNING_KEY:local-dev-signing-key-do-not-use-in-prod}
      ttl-seconds: ${APP_JWT_TTL_SECONDS:3600}
{% endif %}
