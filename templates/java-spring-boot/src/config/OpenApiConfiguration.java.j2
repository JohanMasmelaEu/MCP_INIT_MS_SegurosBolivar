package {{ base_package }}.config;

import io.swagger.v3.oas.models.OpenAPI;
import io.swagger.v3.oas.models.info.Contact;
import io.swagger.v3.oas.models.info.Info;
import io.swagger.v3.oas.models.info.License;
import io.swagger.v3.oas.models.servers.Server;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

import java.util.ArrayList;
import java.util.List;

/**
 * Configuracion de SpringDoc OpenAPI (Swagger UI).
 * Servers dinamicos segun variables de entorno por ambiente.
 */
@Configuration
public class OpenApiConfiguration {

    @Value("${app.openapi.server-local-url:}")
    private String serverLocalUrl;

    @Value("${app.openapi.server-dev-url:}")
    private String serverDevUrl;

    @Value("${app.openapi.server-qa-url:}")
    private String serverQaUrl;

    @Value("${app.openapi.server-prod-url:}")
    private String serverProdUrl;

    @Bean
    public OpenAPI customOpenApi() {
        List<Server> servers = new ArrayList<>();
        addServerIfNotBlank(servers, serverLocalUrl, "Local");
        addServerIfNotBlank(servers, serverDevUrl, "Desarrollo");
        addServerIfNotBlank(servers, serverQaUrl, "QA");
        addServerIfNotBlank(servers, serverProdUrl, "Produccion");

        return new OpenAPI()
                .info(new Info()
                        .title("{{ api_description }}")
                        .description("{{ api_description }}")
                        .version("{{ api_version }}")
                        .contact(new Contact()
                                .name("Equipo {{ project_name }}")
                                .email(""))
                        .license(new License()
                                .name("Apache 2.0")
                                .url("http://www.apache.org/licenses/LICENSE-2.0.html")))
                .servers(servers);
    }

    private void addServerIfNotBlank(List<Server> servers, String url, String description) {
        if (url != null && !url.isBlank()) {
            servers.add(new Server().url(url).description(description));
        }
    }
}
