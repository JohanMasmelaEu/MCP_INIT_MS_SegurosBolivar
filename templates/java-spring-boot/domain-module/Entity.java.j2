package {{ base_package }}.entity;

import jakarta.persistence.Column;
import jakarta.persistence.Entity;
import jakarta.persistence.GeneratedValue;
import jakarta.persistence.GenerationType;
import jakarta.persistence.Id;
import jakarta.persistence.Table;
import lombok.Getter;
import lombok.Setter;
{% for imp in field_imports %}
import {{ imp }};
{% endfor %}

/**
 * Entidad JPA para la tabla {{ module.table_name }}.
 */
@Entity
@Table(name = "{{ module.table_name }}", schema = "{{ c.database.db_schema }}")
@Getter
@Setter
public class {{ module.entity_name }} extends AuditoriaCompleta {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    @Column(name = "id_{{ module.entity_name | lower }}")
    private Long id{{ module.entity_name }};
{% if module.has_cod_field %}

    @Column(name = "cod_{{ module.entity_name | lower }}", unique = true, nullable = false)
    private Long cod{{ module.entity_name }};
{% endif %}
{% for field in module.fields %}

    @Column(name = "{{ field.column_name }}"
    {%- if not field.nullable %}, nullable = false{% endif %}
    {%- if field.unique %}, unique = true{% endif %}
    {%- if field.length %}, length = {{ field.length }}{% endif %})
    private {{ field.field_type.value }} {{ field.name }};
{% endfor %}

    @Column(name = "estado")
    private Boolean estado;
}
