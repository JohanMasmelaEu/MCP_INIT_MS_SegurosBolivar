# Auto detect text files and perform LF normalization
* text=auto

# Java sources
*.java text diff=java
*.gradle text diff=java
*.properties text
*.yaml text
*.yml text

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
