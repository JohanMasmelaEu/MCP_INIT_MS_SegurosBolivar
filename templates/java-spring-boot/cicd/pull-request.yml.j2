name: "Pull Request Workflow"

on:
    pull_request:
        types: [ opened, reopened, synchronize ]
        branches: [ develop, stage, pre, master ]

permissions:
    contents: read
    pull-requests: write

jobs:
    pr-analisys:
        secrets: inherit
        uses: segurosbolivar/devops-actions-pull-request-templates/.github/workflows/template.yml@master
