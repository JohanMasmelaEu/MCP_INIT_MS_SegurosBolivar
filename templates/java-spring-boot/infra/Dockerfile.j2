# Build stage: Gradle + JDK 21
FROM eclipse-temurin:21-jdk-alpine AS builder

WORKDIR /app

COPY gradlew .
COPY gradle gradle
COPY build.gradle settings.gradle ./
COPY src src

ARG ARTIFACTORY_USER
ARG ARTIFACTORY_PASSWORD

ENV ARTIFACTORY_USER=${ARTIFACTORY_USER}
ENV ARTIFACTORY_PASSWORD=${ARTIFACTORY_PASSWORD}

RUN chmod +x gradlew

RUN ./gradlew bootJar -x test --no-daemon \
    -Partifactory_user="${ARTIFACTORY_USER}" \
    -Partifactory_password="${ARTIFACTORY_PASSWORD}"

# Runtime stage: JRE 21 + Datadog Java Agent
FROM eclipse-temurin:21-jre-alpine

WORKDIR /app

RUN addgroup -g 1000 appgroup && adduser -u 1000 -G appgroup -D appuser

ENV ENV_PREFIX=dev
{% if observability.datadog_enabled %}

# Datadog Java Agent (APM + tracing automatico)
ADD https://dtdg.co/latest-java-tracer /app/dd-java-agent.jar

ENV DD_SERVICE=${DD_SERVICE:-{{ dd_service }}}
ENV DD_ENV=${DD_ENV:-local}
ENV DD_VERSION=${DD_VERSION:-0.0.1-SNAPSHOT}
ENV DD_AGENT_HOST=${DD_AGENT_HOST:-datadog-agent}
ENV DD_TRACE_AGENT_PORT=${DD_TRACE_AGENT_PORT:-8126}
{% endif %}

COPY --from=builder /app/build/libs/{{ artifact_name }}-0.0.1-SNAPSHOT.jar app.jar

RUN chown -R appuser:appgroup /app

USER appuser

EXPOSE 8080
{% if observability.datadog_enabled %}

ENTRYPOINT ["java", \
  "-javaagent:/app/dd-java-agent.jar", \
  "-Ddd.service=${DD_SERVICE}", \
  "-Ddd.env=${DD_ENV}", \
  "-Ddd.version=${DD_VERSION}", \
  "-Ddd.logs.injection=true", \
  "-Ddd.trace.analytics.enabled=true", \
  "-Ddd.profiling.enabled=false", \
  "-jar", "app.jar"]
{% else %}

ENTRYPOINT ["java", "-jar", "app.jar"]
{% endif %}
