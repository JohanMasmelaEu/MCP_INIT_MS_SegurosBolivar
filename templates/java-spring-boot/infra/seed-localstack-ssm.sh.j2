#!/bin/sh
# Semilla de parametros SSM en LocalStack para {{ project_name }}
# Ejecutar automaticamente via docker-compose (seed-ssm service)
# o manualmente: AWS_ENDPOINT_URL=http://localhost:{{ localstack_port }} sh seed-localstack-ssm.sh
set -e

ENDPOINT="${AWS_ENDPOINT_URL:-http://localstack:4566}"
export AWS_ACCESS_KEY_ID=test AWS_SECRET_ACCESS_KEY=test AWS_DEFAULT_REGION=us-east-1

put() {
  aws ssm put-parameter --endpoint-url "$ENDPOINT" --region us-east-1 \
    --name "$1" --value "$2" --type String --overwrite 2>/dev/null || true
  echo "  [OK] $1"
}

echo "=== Sembrando parametros SSM en LocalStack ({{ project_name }}) ==="
echo ""

# --- Base de datos ---
echo "-- Base de datos --"
put "{{ db.ssm_endpoint_resolved }}" "jdbc:postgresql://host.docker.internal:{{ db.db_port }}/{{ db.db_name }}"
put "{{ db.ssm_dbname_resolved }}" "{{ db.db_name }}"
put "{{ db.ssm_username_resolved }}" "{{ db.db_user }}"
put "{{ db.ssm_password_resolved }}" "{{ db.db_password }}"
{% if auth_strategy == "machine-to-machine" %}

# --- JWT (Machine-to-machine) ---
echo "-- JWT --"
put "{{ db.ssm_prefix or ssm_app_prefix + '/dev' }}/jwt/signing-key" "local-dev-signing-key-do-not-use-in-prod"
put "{{ db.ssm_prefix or ssm_app_prefix + '/dev' }}/jwt/ttl-seconds" "3600"
{% endif %}
{% if cache == "redis" %}

# --- Redis ---
echo "-- Redis --"
put "{{ db.ssm_prefix or ssm_app_prefix + '/dev' }}/redis/host" "redis"
put "{{ db.ssm_prefix or ssm_app_prefix + '/dev' }}/redis/port" "6379"
{% endif %}

echo ""
echo "=== Parameter Store listo ==="
