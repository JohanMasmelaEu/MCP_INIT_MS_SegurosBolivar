# Variables de entorno para desarrollo local — {{ project_name }}
# Copiar este archivo a la raiz del proyecto como .env y completar los valores.
#
# NOTA: En Docker Compose, todas estas variables se inyectan automaticamente
# por el docker-compose.yml. Este archivo es SOLO para ejecutar con:
#   ./gradlew bootRun (en el host, sin Docker)

# === Artifactory (obligatorias para build) ===
ARTIFACTORY_USER=
ARTIFACTORY_PASSWORD=

# === Entorno ===
ENV_PREFIX=dev

# === Aplicacion ===
SERVER_PORT={{ app_port }}
AWS_ENDPOINT_URL_SSM=http://localhost:{{ localstack_port }}
SPRING_PROFILES_ACTIVE=local
{% if auth_strategy == "oauth2-resource-server" %}

# === OAuth2 (solo para bootRun en host) ===
APP_AUTH_USE_API_GATEWAY=false
APP_OAUTH_COGNITO_DOMAIN=localhost:8090
APP_OAUTH_COGNITO_CLIENT_ID={{ context_path_clean }}-local-client
APP_OAUTH_COGNITO_CLIENT_SECRET={{ context_path_clean }}-local-secret
APP_OAUTH_COGNITO_TOKEN_URI_SCHEME=http
APP_OAUTH_COGNITO_TOKEN_URI_PATH=/default/token
APP_OAUTH_REFRESH_COOKIE_PATH={{ context_path }}
{% elif auth_strategy == "machine-to-machine" %}

# === JWT (solo para bootRun en host) ===
APP_AUTH_USE_API_GATEWAY=false
APP_JWT_SIGNING_KEY=local-dev-signing-key-do-not-use-in-prod
APP_JWT_TTL_SECONDS=3600
{% elif auth_strategy == "api-gateway-delegated" %}

# === API Gateway ===
APP_AUTH_USE_API_GATEWAY=true
{% endif %}
{% if cache == "redis" %}

# === Redis (solo para bootRun en host) ===
APP_REDIS_HOST=localhost
APP_REDIS_PORT={{ redis_port }}
{% endif %}

# Nota: LocalStack esta en puerto {{ localstack_port }}
