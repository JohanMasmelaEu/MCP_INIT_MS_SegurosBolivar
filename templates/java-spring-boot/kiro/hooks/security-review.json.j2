{
  "version": "v1",
  "hooks": [
    {
      "name": "Revision de seguridad en archivos sensibles",
      "trigger": "PostFileSave",
      "matcher": "(Security|Auth|Filter|Interceptor|Config)\\.java$",
      "action": {
        "type": "agent",
        "prompt": "Se ha modificado un archivo de seguridad/configuracion. Verifica:\n1. No se exponen endpoints sin autenticacion accidentalmente\n2. No se deshabilita CSRF o CORS de forma indiscriminada\n3. No se hardcodean secrets, tokens o passwords\n4. Los filtros de seguridad mantienen el orden correcto\n5. Las anotaciones @PreAuthorize/@Secured son coherentes con el diseño\nSi detectas un problema, notifica al usuario con una explicacion clara."
      }
    }
  ]
}
