{
  "version": "v1",
  "hooks": [
    {
      "name": "Verificar estandares de codigo Java",
      "trigger": "PreToolUse",
      "matcher": "fs_write|str_replace|fs_append",
      "action": {
        "type": "agent",
        "prompt": "Antes de escribir este archivo, verifica que el codigo cumple con:\n1. Naming: PascalCase para clases, camelCase para metodos/variables, UPPER_SNAKE para constantes\n2. Estructura: Controller -> Service -> Repository (nunca logica en controller)\n3. Validacion: Usa Jakarta Validation (@Valid, @NotNull, @Size) en DTOs de entrada\n4. Seguridad: Prepared statements (JPA), nunca concatenar SQL, verificar ownership en endpoints\n5. Errores: Excepciones especificas (nunca catch generico), mensajes genericos al cliente\n6. Funciones: Maximo 20 lineas, un solo proposito, maximo 3 parametros\n7. Types: Todo tipado (sin Object, sin raw types), DTOs separados Request/Response\n8. Imports: stdlib -> third-party -> local. Sin imports no usados.\nSi el codigo no cumple, corrigelo antes de escribir."
      }
    }
  ]
}
