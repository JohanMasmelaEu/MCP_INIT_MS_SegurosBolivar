import org.gradle.api.file.DuplicatesStrategy
import org.gradle.testing.jacoco.tasks.JacocoCoverageVerification

plugins {
    id 'org.springframework.boot' version '4.0.2'
    id 'io.spring.dependency-management' version '1.1.7'
    id 'java'
    id 'jacoco'
}

group = '{{ group_id }}'
version = '0.0.1-SNAPSHOT'
description = '{{ api_description }}'

java {
    toolchain {
        languageVersion = JavaLanguageVersion.of(21)
    }
}

configurations {
    compileOnly {
        extendsFrom annotationProcessor
    }
}

def localEnv = [:]
def isLocalExecution = System.getenv("CI") == null && System.getenv("JENKINS_HOME") == null

if (isLocalExecution && file(".env").exists()) {
    file(".env").readLines("UTF-8").each { line ->
        String trimmed = line.trim()
        if (!trimmed || trimmed.startsWith("#") || !trimmed.contains("=")) {
            return
        }
        int separatorIndex = trimmed.indexOf("=")
        String key = trimmed.substring(0, separatorIndex).trim()
        String value = trimmed.substring(separatorIndex + 1).trim()
        if (key) {
            localEnv[key] = value
        }
    }
}

def artifactory_user = findProperty("artifactory_user")
        ?: findProperty("ARTIFACTORY_USER")
        ?: System.getenv("ORG_GRADLE_PROJECT_ARTIFACTORY_USER")
        ?: System.getenv("ORG_GRADLE_PROJECT_artifactory_user")
        ?: System.getenv("ARTIFACTORY_USER")
        ?: System.getenv("artifactory_user")
        ?: localEnv["ARTIFACTORY_USER"]
        ?: localEnv["artifactory_user"]

def artifactory_password = findProperty("artifactory_password")
        ?: findProperty("ARTIFACTORY_PASSWORD")
        ?: System.getenv("ORG_GRADLE_PROJECT_ARTIFACTORY_PASSWORD")
        ?: System.getenv("ORG_GRADLE_PROJECT_artifactory_password")
        ?: System.getenv("ARTIFACTORY_PASSWORD")
        ?: System.getenv("artifactory_password")
        ?: localEnv["ARTIFACTORY_PASSWORD"]
        ?: localEnv["artifactory_password"]

if (!artifactory_user || !artifactory_password) {
    throw new GradleException(
            "Faltan credenciales de Artifactory. Defina ARTIFACTORY_USER y ARTIFACTORY_PASSWORD " +
                    "como variables de entorno/propiedades de Gradle; en local puede usar .env."
    )
}

repositories {
    flatDir { dirs = ["${projectDir}/local-libs"] }

    mavenCentral()

    maven { url = 'https://build.shibboleth.net/maven/releases/' }

    maven {
        url = "{{ artifactory_url }}/jcenter"
        credentials {
            username = "${artifactory_user}"
            password = "${artifactory_password}"
        }
    }

    maven {
        url = "{{ artifactory_url }}/libs-release"
        credentials {
            username = "${artifactory_user}"
            password = "${artifactory_password}"
        }
    }

    maven {
        url = "{{ artifactory_url }}/commons-gradle-error-handling-prod-local/"
        credentials {
            username = "${artifactory_user}"
            password = "${artifactory_password}"
        }
    }

    maven {
        url = "{{ artifactory_url }}/commons-gradle-centralizador-logs-prod-local/"
        credentials {
            username = "${artifactory_user}"
            password = "${artifactory_password}"
        }
    }
}

dependencies {
    // --- Anotaciones ---
    compileOnly 'org.projectlombok:lombok'
    annotationProcessor 'org.projectlombok:lombok'
    testCompileOnly 'org.projectlombok:lombok'
    testAnnotationProcessor 'org.projectlombok:lombok'

    // --- Testing ---
    implementation 'junit:junit'
    testImplementation 'com.github.tomakehurst:wiremock-jre8:2.35.2'
    testImplementation 'org.springframework.boot:spring-boot-starter-test'
    testRuntimeOnly 'org.junit.platform:junit-platform-launcher'
    testImplementation 'org.springframework.boot:spring-boot-starter-security-test'

    // --- Desarrollo ---
    developmentOnly 'org.springframework.boot:spring-boot-devtools'

    // --- Spring Boot Starters ---
    implementation 'org.springframework.boot:spring-boot-starter-actuator'
    testImplementation 'org.springframework.boot:spring-boot-starter-actuator-test'

    implementation 'org.springframework.boot:spring-boot-starter-data-jpa'
    testImplementation 'org.springframework.boot:spring-boot-starter-data-jpa-test'

    runtimeOnly 'com.h2database:h2'
    runtimeOnly 'org.postgresql:postgresql'

    implementation 'org.springframework.boot:spring-boot-starter-security'
    implementation 'org.springframework.boot:spring-boot-starter-security-oauth2-resource-server'
    testImplementation 'org.springframework.boot:spring-boot-starter-security-oauth2-resource-server-test'

    implementation 'org.springframework.boot:spring-boot-starter-validation'
    testImplementation 'org.springframework.boot:spring-boot-starter-validation-test'

    implementation 'org.springframework.boot:spring-boot-starter-webmvc'
    testImplementation 'org.springframework.boot:spring-boot-starter-webmvc-test'

    // --- OpenAPI / Swagger ---
    implementation 'org.springdoc:springdoc-openapi-starter-webmvc-ui:3.0.2'
    testImplementation 'org.springdoc:springdoc-openapi-starter-webmvc-ui:3.0.2'

    // --- WebClient (HTTP saliente) ---
    implementation 'org.springframework.boot:spring-boot-starter-webflux'
    testImplementation 'org.springframework.boot:spring-boot-starter-webflux'

    // --- Logging ---
    implementation 'org.apache.logging.log4j:log4j-api:2.25.3'
    implementation 'org.apache.logging.log4j:log4j-core:2.25.3'

    // --- JSON ---
    implementation 'com.fasterxml.jackson.core:jackson-databind'
    implementation 'com.fasterxml.jackson.core:jackson-annotations'
    implementation 'com.fasterxml.jackson.core:jackson-core'
    implementation 'org.json:json:20231013'

    // --- Apache POI (carga masiva Excel) ---
    implementation 'org.apache.poi:poi-ooxml:5.4.1'

    // --- AWS ---
    implementation 'com.amazonaws:aws-java-sdk-ssm:1.12.722'
    implementation 'com.amazonaws:aws-java-sdk-secretsmanager:1.12.722'
{% if integrations.uses_s3 %}
    implementation 'com.amazonaws:aws-java-sdk-s3:1.12.722'
{% endif %}
{% if integrations.uses_sqs %}
    implementation 'com.amazonaws:amazon-sqs-java-extended-client-lib:2.1.2'
    implementation 'com.amazonaws:aws-java-sdk-sqs:1.12.722'
{% endif %}
{% if integrations.uses_soap %}

    // --- SOAP / WS ---
    implementation 'wsdl4j:wsdl4j'
    implementation 'org.apache.ws.security:wss4j:1.6.19'
    implementation 'org.springframework.ws:spring-ws-core'
    implementation 'org.springframework.ws:spring-ws-support'
    implementation 'org.springframework.ws:spring-ws-security'
    testImplementation 'org.springframework.ws:spring-ws-test'
    implementation 'javax.jws:jsr181-api:1.0-MR1'
    implementation 'javax.xml.ws:jaxws-api:2.3.1'
    implementation 'com.sun.xml.ws:jaxws-rt:2.3.5'
{% endif %}

    // --- Librerias internas Seguros Bolivar ---
    implementation 'com.segurosbolivar.utils:commons-gradle-error-handling-java:1.0.0.RELEASE'
    implementation 'com.bolivar.centralizador.logs:bolivar-centralizador-logs:1.0.0.RELEASE'
    runtimeOnly 'javax.servlet:javax.servlet-api:4.0.1'
}

tasks.named('bootJar') {
    duplicatesStrategy = DuplicatesStrategy.INCLUDE
}

tasks.named('test') {
    useJUnitPlatform()
    finalizedBy(tasks.named('jacocoTestReport'))
    maxParallelForks = 1
}

if (isLocalExecution) {
    tasks.named('bootRun').configure { task ->
        if (localEnv) {
            task.environment.putAll(localEnv)
        }
        task.doFirst {
            System.getenv().each { key, value ->
                if (key != null && value != null && (
                        key.startsWith("APP_OAUTH")
                                || key == "APP_AUTH_USE_API_GATEWAY"
                                || key == "SERVER_PORT"
                                || key == "ENV_PREFIX")) {
                    task.environment.putIfAbsent(key, value)
                }
            }
        }
        task.environment.putIfAbsent("AWS_ACCESS_KEY_ID", "test")
        task.environment.putIfAbsent("AWS_SECRET_ACCESS_KEY", "test")
        task.environment.putIfAbsent("AWS_DEFAULT_REGION", "us-east-1")
        task.environment.putIfAbsent("AWS_ENDPOINT_URL_SSM", "http://localhost:4566")
        task.environment.putIfAbsent("APP_AUTH_USE_API_GATEWAY", "true")
        task.environment.putIfAbsent("ENV_PREFIX", "dev")
        task.environment.putIfAbsent("SERVER_PORT", "8080")
        task.environment.putIfAbsent("APP_OAUTH_COGNITO_CLIENT_ID", "{{ context_path_clean }}-local-client")
        task.environment.putIfAbsent("APP_OAUTH_COGNITO_CLIENT_SECRET", "{{ context_path_clean }}-local-secret")
        task.environment.putIfAbsent("APP_OAUTH_COGNITO_DOMAIN", "localhost:8090")
        task.environment.putIfAbsent("APP_OAUTH_COGNITO_TOKEN_URI_SCHEME", "http")
        task.environment.putIfAbsent("APP_OAUTH_COGNITO_TOKEN_URI_PATH", "/default/token")
        task.environment.putIfAbsent("APP_OAUTH_REFRESH_COOKIE_PATH", "{{ context_path }}")
        task.environment.putIfAbsent("SPRING_PROFILES_ACTIVE", "local")
        task.jvmArgs("-Daws.endpointUrl.ssm=http://localhost:4566")
    }
}

jacoco {
    toolVersion = '0.8.14'
    reportsDirectory = layout.buildDirectory.dir("customJacocoReportDir")
}

tasks.named('jacocoTestReport', org.gradle.testing.jacoco.tasks.JacocoReport) {
    reports {
        xml.required = true
        csv.required = false
        html.outputLocation = layout.buildDirectory.dir("jacoco/jacocoTest")
    }
}

tasks.named('jacocoTestCoverageVerification', JacocoCoverageVerification) {
    dependsOn(tasks.named('test'))
    violationRules {
        rule {
            limit {
                counter = 'LINE'
                value = 'COVEREDRATIO'
                minimum = 0.85
            }
        }
    }
}

tasks.named('check') {
    dependsOn(tasks.named('jacocoTestCoverageVerification'))
}
